<div id="forms" aria-hidden="true" class="popup popup-forms">
    <div class="popup__wrapper">
        <div class="popup__content">
            <div data-close class="popup__close">
                <svg aria-hidden="true" width="17" height="17">
                    <use xlink:href="img/sprite.svg#close"></use>
                </svg>
            </div>
            <div class="popup-forms__body">
                <img loading="lazy" src="img/icons/logo2.svg" alt="" class="popup-forms__logo">
                <div class="popup-forms__title">
                    Остались вопросы?
                </div>
                <form data-dev data-popup-message="#thanks" action="#" class="form">
                    <div class="form__input">
                        <input data-required autocomplete="off" type="text" name="form[]" placeholder="Ваше имя">
                    </div>
                    <div class="form__input">
                        <input data-required autocomplete="off" type="text" name="form[]" placeholder="Город">
                    </div>
                    <div class="form__input">
                        <input data-required autocomplete="off" type="text" name="form[]"
                            placeholder="Контактный телефон">
                    </div>
                    <div class="form__input">
                        <input data-required="email" autocomplete="off" type="text" name="form[]" placeholder="Email">
                    </div>
                    <label class="checkbox">
                        <input data-required class="checkbox__input" type="checkbox" value="1" name="form[]">
                        <span class="checkbox__label">
                            <div class="checkbox__icon">
                                <img loading="lazy" src="img/icons/check.svg" alt="">
                            </div>
                            <a href="./" class="checkbox__text">
                                Нажимая кнопку, вы даете согласие на обработку персональных данных
                            </a>
                        </span>
                    </label>
                    <button type="submit" class="btn">
                        <span>ОТПРАВИТЬ</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="thanks" aria-hidden="true" class="popup popup-forms popup-forms-thanks">
    <div class="popup__wrapper">
        <div class="popup__content">
            <div data-close class="popup__close">
                <svg aria-hidden="true" width="17" height="17">
                    <use xlink:href="img/sprite.svg#close"></use>
                </svg>
            </div>
            <div class="popup-forms__body">
                <img loading="lazy" src="img/icons/logo2.svg" alt="" class="popup-forms__logo">
                <div class="popup-forms__title">
                    Спасибо!
                </div>
                <p>
                    Данные успешно отправлены
                </p>
                <button type="button" data-close class="btn">
                    <span>отлично</span>
                </button>
            </div>
        </div>
    </div>
</div>